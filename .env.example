# Copy this file to .env and fill in your credentials. Never commit .env.
# All data sources in this project are 100% free-tier / public scraping.
# Only two services require API credentials:

# Kaggle (free account — used for March Mania historical datasets + spread archives)
KAGGLE_USERNAME=
KAGGLE_KEY=

# Weights & Biases (free account — experiment tracking and artifact logging)
WANDB_API_KEY=
WANDB_PROJECT=mm-stgnn
WANDB_ENTITY=

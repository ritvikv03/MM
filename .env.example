# Copy this file to .env and fill in your credentials. Never commit .env.
# All data sources are 100% free-tier / public scraping.

# ── Kaggle ────────────────────────────────────────────────────────────────────
# Free account. Used for March Mania historical datasets and spread archives.
# Get at: https://www.kaggle.com → Account → API → Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Free account. Experiment tracking, calibration curves, artifact logging.
# Get at: https://wandb.ai → Settings → API Keys → New Key
WANDB_API_KEY=
WANDB_PROJECT=mm-stgnn
WANDB_ENTITY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Free project (500MB). Postgres database + Realtime subscriptions.
# Create at: https://supabase.com → New Project
# Then go to: Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=        # Service role key — backend/GitHub Actions ONLY, never frontend
SUPABASE_ANON_KEY=           # Anon key — safe for frontend/Vercel

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix makes these available in the browser bundle.
# Set these as Vercel Environment Variables in your project dashboard.
NEXT_PUBLIC_API_URL=         # URL of your deployed FastAPI backend (e.g. https://your-app.railway.app)
NEXT_PUBLIC_SUPABASE_URL=    # Same value as SUPABASE_URL above
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Same value as SUPABASE_ANON_KEY above

# ── GitHub Actions ────────────────────────────────────────────────────────────
# Add ALL of the above as GitHub Repository Secrets for the 3x daily pipeline.
# Go to: github.com/ritvikv03/MM → Settings → Secrets and variables → Actions
VERCEL_CRON_SECRET=          # Random string — shared secret for cron webhook auth
